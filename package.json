{
  "name": "praxia",
  "version": "1.0.1",
  "description": "Praxia is the action layer for Cognia reports. It reads analysis from cognia/, then proposes and, after explicit approval, applies scoped fixes or writes suggestions to praxia/.",
  "type": "module",
  "bin": {
    "praxia": "bin/install.js"
  },
  "scripts": {
    "postinstall": "node bin/install.js",
    "uninstall": "node bin/install.js --uninstall",
    "sync:wrappers": "node scripts/sync-wrappers.js",
    "check:wrappers": "node scripts/sync-wrappers.js --check",
    "check:docs": "node scripts/check-docs.js"
  },
  "keywords": [
    "ai",
    "agents",
    "copilot",
    "developer-assistant",
    "optimization",
    "refactoring",
    "bug fixing",
    "architecture",
    "praxia"
  ],
  "license": "MIT",
  "files": [
    "AGENTS.md",
    "README.md",
    "bin/",
    "scripts/",
    ".github/agents",
    ".github/skills",
    ".github/roster.json",
    ".claude/agents",
    ".claude/skills",
    ".codex/skills",
    ".cursor/agents",
    ".cursor/agents.json"
  ]
}
